{{ 'body-type-quiz.css' | asset_url | stylesheet_tag }}

<section class="body-type-story-guide color-{{ section.settings.color_scheme }}">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="body-type-story-guide__inner">
      <div class="body-type-story-guide__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="body-type-story-guide__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="body-type-story-guide__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.text != blank -%}
          <div class="body-type-story-guide__text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        <div class="body-type-story-guide__steps">
          {%- for block in section.blocks -%}
            {%- if block.type == 'step' -%}
              <div class="body-type-story-guide__step" {{ block.shopify_attributes }}>
                <span class="body-type-story-guide__step-index">{{ forloop.index }}</span>
                <div>
                  <p class="body-type-story-guide__step-title">{{ block.settings.title | escape }}</p>
                  <p class="body-type-story-guide__step-text">{{ block.settings.text | escape }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="body-type-story-guide__actions">
          {%- if section.settings.quiz_label != blank -%}
            <a class="button button--primary" href="{{ section.settings.quiz_link | default: routes.root_url }}">
              {{ section.settings.quiz_label | escape }}
            </a>
          {%- endif -%}
          {%- if section.settings.shop_label != blank -%}
            <a class="button button--secondary" href="{{ section.settings.shop_link | default: routes.all_products_collection_url }}">
              {{ section.settings.shop_label | escape }}
            </a>
          {%- endif -%}
        </div>
        {%- if section.settings.note != blank -%}
          <p class="body-type-story-guide__note">{{ section.settings.note | escape }}</p>
        {%- endif -%}
      </div>

      <div class="body-type-story-guide__visual-grid">
        <div class="body-type-story-guide__image body-type-story-guide__image--primary">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                widths: '360, 540, 720, 1000',
                sizes: '(min-width: 990px) 44vw, 92vw',
                alt: section.settings.heading
            }}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="body-type-story-guide__image body-type-story-guide__image--secondary">
          {%- if section.settings.image_2 != blank -%}
            {{
              section.settings.image_2
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                widths: '320, 480, 640, 800',
                sizes: '(min-width: 990px) 28vw, 92vw',
                alt: section.settings.secondary_image_alt
            }}
          {%- else -%}
            {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Body type story guide",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Primary image" },
    { "type": "image_picker", "id": "image_2", "label": "Secondary image" },
    { "type": "text", "id": "secondary_image_alt", "label": "Secondary image alt text", "default": "Wellness product ritual" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Story-led guidance" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From body signals to a daily ritual" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Body constitution ideas can make wellness shopping feel more personal. Start with how your energy, temperature, digestion, sleep, and mood tend to show up, then choose a supportive formula for daily care.</p>"
    },
    { "type": "text", "id": "quiz_label", "label": "Quiz button label", "default": "Take the Quiz" },
    { "type": "url", "id": "quiz_link", "label": "Quiz button link" },
    { "type": "text", "id": "shop_label", "label": "Shop button label", "default": "Shop all formulas" },
    { "type": "url", "id": "shop_link", "label": "Shop button link" },
    {
      "type": "text",
      "id": "note",
      "label": "Compliance note",
      "default": "Results are wellness references only and do not diagnose, treat, cure, or confirm a condition."
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 64 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Guide step",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Notice your pattern" },
        { "type": "text", "id": "text", "label": "Text", "default": "Answer simple lifestyle questions and see which daily support direction may fit." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Body type story guide",
      "blocks": [
        { "type": "step", "settings": { "title": "Read your daily signals", "text": "Energy, temperature, digestion, sleep, and mood shape the recommendation." } },
        { "type": "step", "settings": { "title": "Match a tendency", "text": "The quiz weighs several constitution-inspired dimensions and shows the strongest tendency." } },
        { "type": "step", "settings": { "title": "Shop with context", "text": "Each result suggests one main formula and one pairing for a simple routine." } }
      ]
    }
  ]
}
{% endschema %}

{{ 'body-type-quiz.css' | asset_url | stylesheet_tag }}

<section class="body-type-story-hero color-{{ section.settings.color_scheme }}">
  <div class="body-type-story-hero__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          alt: section.settings.heading
      }}
    {%- else -%}
      <div class="body-type-story-hero__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
  </div>
  <div class="body-type-story-hero__overlay" aria-hidden="true"></div>
  <div class="body-type-story-hero__content page-width">
    <div class="body-type-story-hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="body-type-story-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="body-type-story-hero__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h1>
      {%- if section.settings.text != blank -%}
        <div class="body-type-story-hero__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
      <div class="body-type-story-hero__actions">
        {%- if section.settings.primary_label != blank -%}
          <a class="button button--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
            {{ section.settings.primary_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a class="button button--secondary" href="{{ section.settings.secondary_link | default: section.settings.quiz_page_url }}">
            {{ section.settings.secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="body-type-story-hero__trust" aria-label="Wellness promises">
    {%- for block in section.blocks -%}
      <div class="body-type-story-hero__trust-item" {{ block.shopify_attributes }}>
        {{ block.settings.text | escape }}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Body type story hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Daily wellness by body tendency"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find the ritual that fits how your body feels today"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h0",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Explore story-led wellness formulas inspired by traditional body constitution patterns. This guide offers daily health reference only, not diagnosis or treatment.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop daily rituals"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Find My Best Match"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "url",
      "id": "quiz_page_url",
      "label": "Fallback quiz page URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Personalized daily support"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Body type story hero",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "10-question guided match" } },
        { "type": "trust_item", "settings": { "text": "Health reference, not diagnosis" } },
        { "type": "trust_item", "settings": { "text": "Shop formulas by daily tendency" } }
      ]
    }
  ]
}
{% endschema %}
